    <!-- Privacy Policy Strings -->
    <string name="title_privacy_policy">Privacy Policy</string>
    <string name="privacy_last_updated">Last updated: October 24, 2023</string>
    <string name="privacy_intro">This policy describes how the Canteen Management System (\"we\", \"our\", or \"us\") handles your information.</string>

    <string name="privacy_collection_title">Data Collection</string>
    <string name="privacy_collection_desc">We collect information necessary to provide efficient canteen services and maintain high-security standards within the corporate ecosystem.</string>
    <string name="privacy_collection_bullet_1"><b>Personal Identifiers:</b> Staff name, employee ID, and corporate email address.</string>
    <string name="privacy_collection_bullet_2"><b>Transaction Data:</b> Meal selections, timestamps, and wallet balance history.</string>
    <string name="privacy_collection_bullet_3"><b>Access Logs:</b> Device type and login activity for security auditing.</string>

    <string name="privacy_usage_title">Data Usage</string>
    <string name="privacy_usage_desc">Your information is processed to optimize canteen operations and personalize your dining experience.</string>
    <string name="privacy_usage_op_title">OPERATIONAL</string>
    <string name="privacy_usage_op_desc">To process orders, manage wallet balances, and track inventory levels in real-time.</string>
    <string name="privacy_usage_admin_title">ADMINISTRATIVE</string>
    <string name="privacy_usage_admin_desc">To generate revenue reports and monitor canteen traffic patterns for better staffing.</string>

    <string name="privacy_protection_title">Data Protection</string>
    <string name="privacy_protection_desc">We employ industry-standard encryption and security protocols to safeguard your sensitive information from unauthorized access.</string>
    <string name="privacy_protection_e2e_title">End-to-End Encryption</string>
    <string name="privacy_protection_e2e_desc">All data transmitted between your device and our servers is secured using SSL/TLS 1.3 protocols.</string>
    <string name="privacy_protection_access_title">Restricted Access</string>
    <string name="privacy_protection_access_desc">Only authorized canteen administrators can view transaction data relevant to their operational roles.</string>

    <string name="privacy_retention_title">Data Retention</string>
    <string name="privacy_retention_desc">We retain your personal data only for as long as your corporate account is active. Financial records are kept for a period of 7 years to comply with tax and audit regulations, after which they are securely purged from our systems.</string>

    <string name="privacy_compliance_note">Your data is currently managed in compliance with GDPR and local privacy laws.</string>
