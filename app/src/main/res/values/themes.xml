<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CanteenManagementSystem" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>

        <!-- Surface and background -->
        <item name="android:windowBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorOutline">@color/color_outline</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Secondary color for accents -->
        <item name="colorSecondary">@color/semantic_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Error and Warning -->
        <item name="colorError">@color/color_error</item>

        <!-- Bottom Navigation Style -->
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.App.BottomNavigationView.ActiveIndicator</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="Widget.App.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/green_light</item>
    </style>

    <style name="ShapeAppearance.TopRounded" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>