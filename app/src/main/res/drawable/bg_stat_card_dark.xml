<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/primary_dark" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Inner Ring -->
    <item android:gravity="bottom|end" android:bottom="-30dp" android:right="-30dp">
        <shape android:shape="oval">
            <size android:width="100dp" android:height="100dp" />
            <stroke android:width="15dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
    <!-- Outer Ring -->
    <item android:gravity="bottom|end" android:bottom="-60dp" android:right="-60dp">
        <shape android:shape="oval">
            <size android:width="140dp" android:height="140dp" />
            <stroke android:width="15dp" android:color="#0DFFFFFF" />
        </shape>
    </item>
</layer-list>